{% liquid
  assign section_st = section.settings
  assign product = closest.product
  assign enable_skeleton_loading = section_st.enable_skeleton_loading
%}

{%- if product.tags contains 'compra-internacional' -%}
  <div class="intl-delivery-info mb-25" {{ block.shopify_attributes }} style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:#fff8f0;border:1.5px solid #f4a84a;border-radius:8px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f4a84a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
      <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
    </svg>
    <span style="font-size:13px;font-weight:600;color:#c47a00;">El pedido llega en aproximadamente 15 días</span>
  </div>
{%- else -%}
  <div
    class="pickup_avaiability mb-25{% if enable_skeleton_loading %} skeleton-loading{% endif %}"
    {{ block.shopify_attributes }}
  >
    {%- render 'pickup-availability', product: product -%}
  </div>
{%- endif -%}
{% schema %}
{
  "name": "t:blocks.product.pickup_availability.name",
  "tag": null,
  "presets": [
    {
      "name": "t:blocks.product.pickup_availability.name"
    }
  ]
}
{% endschema %}
